# ANGEL Discord Bot Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# REQUIRED
# ============================================

# Your Discord bot token from Developer Portal
# Get this from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# ============================================
# OPTIONAL (defaults provided)
# ============================================

# Backend API URL (where your ANGEL backend is running)
# Local development: http://localhost:3000
# Production: https://your-backend.railway.app
BACKEND_URL=http://localhost:3000

# Your Discord server ID (optional, but recommended)
# Get this by: right-click server → Copy Server ID (enable Developer Mode)
# If not set, commands work in all servers you add the bot to
GUILD_ID=

# ============================================
# OPTIONAL: Advanced Settings
# ============================================

# Enable debug logging
DEBUG=false

# Command timeout in milliseconds (how long to wait for backend response)
COMMAND_TIMEOUT=5000

# Auto-update command list on startup
AUTO_UPDATE_COMMANDS=true
